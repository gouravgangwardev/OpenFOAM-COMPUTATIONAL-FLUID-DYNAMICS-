FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Air properties at approximately 30 degC (303 K)
// rho   = 1.164 kg/m3
// mu    = rho * nu = 1.164 * 1.6e-5 = 1.862e-5 Pa.s
// Cp    = 1007 J/kg/K
// kappa = 0.026 W/m/K
// Pr    = mu*Cp/kappa = 1.862e-5 * 1007 / 0.026 = 0.721

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles      1;
        molWeight   28.97;
    }

    equationOfState
    {
        rho         1.164;
    }

    thermodynamics
    {
        Cp          1007;
        Hf          0;
    }

    transport
    {
        mu          1.862e-05;    // dynamic viscosity [Pa.s]
        Pr          0.7207;       // Prandtl number
    }
}

